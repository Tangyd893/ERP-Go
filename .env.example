# ============================================================
# ERP-Go 本地开发环境变量配置模板
# 复制此文件为 .env 并修改对应值
# ============================================================

# 运行环境: development | testing | production
ENVIRONMENT=development

# ============================================================
# PostgreSQL 数据库
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp123
POSTGRES_DB=erp_go

# ============================================================
# Redis 缓存
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================
# RabbitMQ 消息队列
# ============================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================
# MinIO 对象存储
# ============================================================
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=erp-go

# ============================================================
# OpenSearch 搜索
# ============================================================
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin123

# ============================================================
# 可观测性
# ============================================================
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
JAEGER_PORT=16686

# ============================================================
# 服务端口规划
# ============================================================
# API 网关: 8080
# IAM 认证权限服务: 8081
# 租户组织服务: 8082
# 商品服务: 8083
# 渠道服务: 8084
# 订单服务: 8085
# 库存服务: 8086
# WMS 仓储服务: 8087
# TMS 物流服务: 8088
# 文件服务: 8089
# 采购服务: 8091
# 财务服务: 8092
# 报表服务: 8093
# 通知服务: 8094

# ============================================================
# 前端端口
# ============================================================
ADMIN_WEB_PORT=5173
WAREHOUSE_PDA_PORT=5174
DASHBOARD_WEB_PORT=5175

# ============================================================
# 服务目标地址（网关代理用）
# ============================================================
SERVICE_TARGET_IAM=http://localhost:8081
SERVICE_TARGET_TENANT=http://localhost:8082
SERVICE_TARGET_PRODUCT=http://localhost:8083
SERVICE_TARGET_CHANNEL=http://localhost:8084
SERVICE_TARGET_ORDER=http://localhost:8085
SERVICE_TARGET_INVENTORY=http://localhost:8086
SERVICE_TARGET_WAREHOUSE=http://localhost:8087
SERVICE_TARGET_TRANSPORT=http://localhost:8088
SERVICE_TARGET_FILE=http://localhost:8089
